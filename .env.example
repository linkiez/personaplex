# ===================================================
# VoxPulse Realtime Voice Hub - Environment Template
# ===================================================
# Copy this file to .env and set real values.
#   cp .env.example .env

# ===================================================
# LocalAI - LLM Backend
# ===================================================

# Base URL for LocalAI (OpenAI-compatible API)
LOCALAI_BASE_URL=http://localhost:8080

# Loaded model name in LocalAI
LOCALAI_MODEL=mistral

# ===================================================
# Moshi Voice Server
# ===================================================

# WebSocket server host
MOSHI_HOST=127.0.0.1

# WebSocket server port
MOSHI_PORT=8998

# Runtime device (cuda, cpu)
MOSHI_DEVICE=cuda

# Use CPU offload when GPU memory is limited
MOSHI_CPU_OFFLOAD=false

# Voice prompt directory (empty = default prompts)
MOSHI_VOICE_PROMPT_DIR=

# SSL certificate directory (empty = auto-generate)
MOSHI_SSL_DIR=

# ===================================================
# OpenClaw Monitor
# ===================================================

# OpenClaw WebSocket endpoint
OPENCLAW_WS=ws://host.docker.internal:7000/ws/audio

# Moshi WebSocket endpoint used by monitor
MOSHI_WS=ws://moshi-voice:8998/api/chat

# Query worker_auth_id sent to Moshi
MOSHI_WORKER_AUTH_ID=silence_check

# Monitor reconnect delay (seconds)
OPENCLAW_RECONNECT_DELAY=2.0

# Mirror output audio as base64 JSON (true/false)
OPENCLAW_AUDIO_JSON_OUT=false

# Emit extracted actions to OpenClaw (true/false)
OPENCLAW_EMIT_ACTIONS=false

# Action pipeline thresholds and safety limits
OPENCLAW_ACTION_MIN_CONFIDENCE=0.75
OPENCLAW_MAX_ACTION_DISTANCE_M=2.0
OPENCLAW_MAX_ACTION_SPEED_MPS=1.2
OPENCLAW_MAX_ACTION_ANGLE_DEG=180.0
OPENCLAW_MIN_OBSTACLE_DISTANCE_M=0.3
OPENCLAW_MIN_BATTERY_PCT=5.0
OPENCLAW_SENSOR_STALE_AFTER_MS=3000

# Optional HTTP endpoint for approved action dispatch to ROS gateway
OPENCLAW_ROSBRIDGE_HTTP_ENDPOINT=
OPENCLAW_ROSBRIDGE_TIMEOUT_S=1.5
OPENCLAW_ROSBRIDGE_AUTH_TOKEN=

# Optional extra args for monitor
OPENCLAW_EXTRA_ARGS=

# ===================================================
# Phase 3 - API Server (Node.js/Express)
# ===================================================

# API server port
API_PORT=3001

# PostgreSQL connection URL
DATABASE_URL=postgres://moshi:password@jcm-db:5432/moshi_voice

# JWT secret for access tokens (min 32 chars)
JWT_SECRET=change-me-to-random-secret-at-least-32-chars

# JWT secret for refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET=change-me-to-another-random-secret-32-chars

# Node runtime environment
NODE_ENV=production

# ===================================================
# Phase 3 - Keycloak OIDC
# ===================================================

# Keycloak base URL (example: https://jcm/keycloak)
KEYCLOAK_URL=https://jcm/keycloak

# Keycloak realm name
KEYCLOAK_REALM=moshi

# Registered Keycloak client ID
KEYCLOAK_CLIENT_ID=moshi-voice

# Keycloak client secret
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret

# Redirect URI after authentication (must be registered in Keycloak)
KEYCLOAK_REDIRECT_URI=https://yourdomain.com/auth/oidc/callback

# ===================================================
# Phase 3 - Analytics (Fluentd)
# ===================================================

# Fluentd HTTP input URL
FLUENTD_URL=http://jcm:9880

# Event tag prefix (example: moshi.prod or moshi.dev)
FLUENTD_TAG=moshi.prod

# ===================================================
# Phase 3 - Cache (Redis)
# ===================================================

# Redis connection URL (empty = in-memory fallback cache)
REDIS_URL=redis://jcm:6379
