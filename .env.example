# ===================================================
# VoxPulse Realtime Voice Hub - Arquivo de Configuração de Ambiente
# ===================================================
#
# Copie este arquivo para .env e preencha os valores
#   cp .env.example .env
#

# ===================================================
# LocalAI — Backend LLM
# ===================================================

# URL base do LocalAI (OpenAI-compatible API)
LOCALAI_BASE_URL=http://localhost:8080

# Nome do modelo carregado no LocalAI
LOCALAI_MODEL=mistral

# ===================================================
# Servidor Moshi
# ===================================================

# Host do servidor WebSocket
MOSHI_HOST=127.0.0.1

# Porta do servidor WebSocket
MOSHI_PORT=8998

# Device para rodar o codec MIMI (cuda, cpu)
MOSHI_DEVICE=cuda

# Usar CPU offload se GPU tem pouca memória
MOSHI_CPU_OFFLOAD=false

# Diretório de voice prompts (deixar vazio para padrão)
MOSHI_VOICE_PROMPT_DIR=

# Caminho do certificado SSL (deixar vazio para gerar automático)
MOSHI_SSL_DIR=

# ===================================================
# OpenClaw Monitor
# ===================================================

# Endpoint WebSocket do OpenClaw
OPENCLAW_WS=ws://host.docker.internal:7000/ws/audio

# Endpoint WebSocket do Moshi para o monitor
MOSHI_WS=ws://moshi-voice:8998/api/chat

# Query worker_auth_id enviada ao Moshi
MOSHI_WORKER_AUTH_ID=silence_check

# Delay de reconexão do monitor
OPENCLAW_RECONNECT_DELAY=2.0

# Habilita espelhamento de áudio em JSON base64 (true/false)
OPENCLAW_AUDIO_JSON_OUT=false

# Habilita emissão de ações extraídas para OpenClaw (true/false)
OPENCLAW_EMIT_ACTIONS=false

# Threshold e limites de segurança da pipeline de ações
OPENCLAW_ACTION_MIN_CONFIDENCE=0.75
OPENCLAW_MAX_ACTION_DISTANCE_M=2.0
OPENCLAW_MAX_ACTION_SPEED_MPS=1.2
OPENCLAW_MAX_ACTION_ANGLE_DEG=180.0
OPENCLAW_MIN_OBSTACLE_DISTANCE_M=0.3
OPENCLAW_MIN_BATTERY_PCT=5.0
OPENCLAW_SENSOR_STALE_AFTER_MS=3000

# Endpoint opcional para envio HTTP de acoes aprovadas para gateway ROS
OPENCLAW_ROSBRIDGE_HTTP_ENDPOINT=
OPENCLAW_ROSBRIDGE_TIMEOUT_S=1.5
OPENCLAW_ROSBRIDGE_AUTH_TOKEN=

# Args extras opcionais para o monitor
OPENCLAW_EXTRA_ARGS=

# ===================================================
# Fase 3 — API Server (Node.js/Express)
# ===================================================

# Porta do servidor API
API_PORT=3001

# Conexão PostgreSQL (instância no jcm server)
DATABASE_URL=postgres://moshi:password@jcm-db:5432/moshi_voice

# Segredo JWT para access tokens (mínimo 32 chars)
JWT_SECRET=change-me-to-random-secret-at-least-32-chars

# Segredo JWT para refresh tokens (diferente do JWT_SECRET)
JWT_REFRESH_SECRET=change-me-to-another-random-secret-32-chars

# Node environment
NODE_ENV=production

# ===================================================
# Fase 3 — Keycloak OIDC
# ===================================================

# URL base do servidor Keycloak (ex: https://jcm/keycloak)
KEYCLOAK_URL=https://jcm/keycloak

# Nome do realm configurado no Keycloak
KEYCLOAK_REALM=moshi

# Client ID registrado no Keycloak
KEYCLOAK_CLIENT_ID=moshi-voice

# Client Secret (obtido em Keycloak > Clients > moshi-voice > Credentials)
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret

# URI de redirecionamento após autenticação (deve estar registrada no Keycloak)
KEYCLOAK_REDIRECT_URI=https://yourdomain.com/auth/oidc/callback

# ===================================================
# Fase 3 — Analytics (Fluentd)
# ===================================================

# URL do Fluentd HTTP input (ex: http://jcm:9880)
FLUENTD_URL=http://jcm:9880

# Tag base dos eventos (ex: moshi.prod ou moshi.dev)
FLUENTD_TAG=moshi.prod

# ===================================================
# Fase 3 — Cache (Redis)
# ===================================================

# URL de conexão Redis (deixar vazio para usar cache em memória)
REDIS_URL=redis://jcm:6379
